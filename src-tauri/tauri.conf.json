{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MattsSoftware",
  "version": "0.1.0",
  "identifier": "com.mattssoftware.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MattsSoftware",
        "width": 1180,
        "height": 800,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 22 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://github.com https://*.githubusercontent.com; font-src 'self' data:; img-src 'self' data: blob: asset: https://asset.localhost; media-src 'self' data: blob:;"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
