<?xml version="1.0" encoding="UTF-8"?>
<!--
  Launcher host entitlements.

  HISTORICAL ATTEMPT: added `com.apple.developer.applesignin` here
  so a merged Tap pane's ASAuthorizationAppleIDProvider call (which
  runs in this process) would succeed. That signed the binary fine,
  but at launch macOS refused it with `Launchd job spawn failed`
  (POSIX 163) — the entitlement is rejected unless the App ID
  `com.mattssoftware.launcher` ALSO has "Sign in with Apple"
  enabled at developer.apple.com → Identifiers. Until that's
  added, the entitlement makes the binary unlaunchable.

  Reverted to an empty entitlements set so the launcher boots.
  Re-add the applesignin block (see git history) once the portal
  capability is in place.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict/>
</plist>
