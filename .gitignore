# SwiftPM build products + the packaged .app — regenerated by
# `swift build` / `./package.sh`, never committed. The squircle
# PNGs under Sources/.../Resources ARE source and stay tracked.
.build/
.swiftpm/
dist/
*.xcodeproj
.DS_Store
*.log

# Packaged disk image — a GitHub-release asset, never committed.
*.dmg
